FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx

# Optional but recommended when "Encrypt Key" is enabled in Feishu callbacks.
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxx

# Bot custom menu event key configured in Feishu Open Platform.
FEISHU_MENU_EVENT_KEY=analyze_stock

# Use https://open.larksuite.com for Lark international tenants.
FEISHU_API_BASE_URL=https://open.feishu.cn

# Set to true only for local debugging if your callback request has no Lark signature headers.
FEISHU_SKIP_SIGNATURE=false
